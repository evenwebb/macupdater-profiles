{
  "name": "Nextcloud Desktop",
  "slug": "nextcloud",
  "description": "Self-hosted productivity platform , sync, share, and collaborate on files, calendars, contacts, and more",
  "website": "https://nextcloud.com",
  "platform": "macOS",
  "architecture": "universal",
  "bundle_id": "com.nextcloud.talk.mac",
  "category": "cloud-backup",
  "license": "free",
  "min_os": "macOS 12.0",
  "auto_updates": true,
  "skip": false,
  "version_check": {
    "method": "github_api",
    "url": "https://api.github.com/repos/nextcloud/desktop/releases/latest",
    "extraction": {
      "type": "json_path",
      "path": "tag_name"
    }
  },
  "download": {
    "method": "direct_url",
    "url": "https://nextcloud.com/install",
    "file_type": "pkg"
  },
  "changelog": {
    "method": "github_api",
    "url": "https://api.github.com/repos/nextcloud/desktop/releases/latest"
  },
  "release_date": {
    "method": "github_api",
    "field": "published_at"
  },
  "last_updated": "2026-06-22",
  "cf_bundle_version": "2.2.0",
  "uses_electron": true,
  "icons": {
    "direct_url": "https://raw.githubusercontent.com/evenwebb/macupdater-profiles/main/icons/nextcloud.png"
  }
}

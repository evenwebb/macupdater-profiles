{
  "name": "Paste",
  "url": "https://pasteapp.io",
  "description": "Clipboard manager for Mac",
  "version_check": {
    "method": "redirect_trace",
    "url": "https://hub.pasteapp.io/downloads/stable/latest",
    "extraction": "Follow 302 redirect, extract version from Location header filename: Paste-{VERSION}.zip",
    "pattern": "Paste-(.+)\\.zip",
    "version_example": "6.6.2",
    "headers": {}
  },
  "download": {
    "url": "https://downloads.pasteapp.io/dist/stable/Paste-{VERSION}.zip",
    "file_type": "zip",
    "headers": {}
  },
  "changelog": {
    "url": "https://pasteapp.io/updates",
    "method": "web_page",
    "note": "Organized by feature name, not per-version"
  },
  "release_date": {
    "method": "http_last_modified",
    "field": "last-modified",
    "source": "S3 ZIP file header"
  },
  "sparkle": null,
  "architecture": "universal",
  "min_os": "11.0",
  "auto_updates": false,
  "app_store_only": false,
  "infrastructure": {
    "hosting": "Vercel-hosted redirect endpoint",
    "cdn": "S3 behind CloudFront"
  },
  "notes": "No Sparkle at all. Version detection relies entirely on the HTTP redirect from the Vercel endpoint.",
  "$schema": "https://raw.githubusercontent.com/evenwebb/macupdater-profiles/main/schema.json",
  "category": "utilities",
  "license": "paid",
  "skip": false,
  "bundle_id": "com.wiheads.paste",
  "last_updated": "2026-06-21",
  "slug": "paste"
}

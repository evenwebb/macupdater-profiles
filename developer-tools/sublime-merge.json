{
  "name": "Sublime Merge",
  "slug": "sublime-merge",
  "description": "Git GUI",
  "website": "https://www.sublimemerge.com",
  "platform": "macOS",
  "architecture": "universal",
  "min_os": "10.9",
  "auto_updates": true,
  "version_check": {
    "method": "rest_api_json",
    "url": "https://www.sublimemerge.com/updates/stable_update_check",
    "extraction": {
      "type": "json_path",
      "json_path": "$.latest_version"
    },
    "headers": {}
  },
  "download": {
    "method": "composed_url",
    "url_or_pattern": "https://download.sublimetext.com/sublime_merge_osx_{build}.pak.xz",
    "file_type": "pak.xz",
    "headers": {}
  },
  "changelog": {
    "method": "fixed_url",
    "url": "https://www.sublimemerge.com/download"
  },
  "release_date": {
    "method": "download_page",
    "field": null
  },
  "notes": "NOT Sparkle. Custom JSON update system (same as Sublime Text). $.latest_version is integer (e.g. 2125). Paid license. Release date listed on download page per build, not in JSON response.",
  "last_updated": "2026-06-21",
  "$schema": "https://raw.githubusercontent.com/evenwebb/macupdater-profiles/main/schema.json",
  "category": "developer-tools",
  "license": "paid",
  "skip": false,
  "bundle_id": "com.sublimemerge"
}

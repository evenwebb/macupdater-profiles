  },
  "release_date": {
    "method": "pubDate",
    "field": "pubDate"
  },
  "notes": "Sparkle 2. Download URL always fetches latest v8. Changelog embedded in appcast <description> as HTML. Also available on Mac App Store and Setapp. Paid one-time purchase.",

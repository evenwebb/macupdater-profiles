    "extraction": {
      "type": "sparkle_xml",
      "version_field": "sparkle:version on enclosure",
      "example": "15.x"
    },
    "headers": {}
  },
  "download": {
    "method": "static_redirect_url",
    "url": "https://download.teamviewer.com/download/TeamViewer.dmg",
    "file_type": "dmg",
    "headers": {}
  },
  "changelog": {
    "method": "web_scrape",
    "url": "https://community.teamviewer.com/English/categories/change-logs-en/"
  },
  "release_date": {
    "method": "sparkle_pub_date",
    "field": "pubDate in Sparkle XML (ISO 8601)"

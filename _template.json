{
  "$schema": "https://raw.githubusercontent.com/evenwebb/macupdater-profiles/main/schema.json",
  "name": "App Name",
  "slug": "app-slug",
  "bundle_id": "com.example.app",
  "category": "utilities",
  "license": "free",
  "description": "What the app does — one sentence",
  "website": "https://example.com",
  "platform": "macOS",
  "architecture": "universal",
  "min_os": "12.0",
  "auto_updates": false,
  "skip": false,
  "version_check": {
    "method": "sparkle_appcast",
    "url": "https://example.com/appcast.xml",
    "extraction": {
      "type": "sparkle_xml",
      "version_field": "sparkle:shortVersionString"
    },
    "headers": {},
    "rate_limit": ""
  },
  "download": {
    "method": "direct_url",
    "url": "https://example.com/download/App-{VERSION}.dmg",
    "file_type": "dmg",
    "headers": {},
    "note": "For separate arch downloads, use {ARCH} in URL (resolves to arm64 or x86_64 at runtime)"
  },
  "changelog": {
    "method": "web_scrape",
    "url": "https://example.com/release-notes"
  },
  "release_date": {
    "method": "sparkle_pub_date",
    "field": "pubDate in appcast"
  },
  "notes": "Any quirks, Cloudflare issues, auth requirements, etc.",
  "last_updated": "2026-06-21"
}

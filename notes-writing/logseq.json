{
  "name": "Logseq",
  "slug": "logseq",
  "description": "Privacy-first, open-source knowledge base that works on top of local plain-text Markdown and Org-mode files",
  "website": "https://logseq.com",
  "platform": "macOS",
  "architecture": "universal",
  "bundle_id": "com.electron.logseq",
  "category": "notes-writing",
  "license": "free",
  "min_os": "macOS 10.14",
  "auto_updates": true,
  "skip": false,
  "version_check": {
    "method": "github_api",
    "url": "https://api.github.com/repos/logseq/logseq/releases/latest",
    "extraction": {
      "type": "json_path",
      "path": "tag_name"
    }
  },
  "download": {
    "method": "direct_url",
    "url": "https://github.com/logseq/logseq/releases/latest",
    "file_type": "dmg"
  },
  "changelog": {
    "method": "github_api",
    "url": "https://api.github.com/repos/logseq/logseq/releases/latest"
  },
  "release_date": {
    "method": "github_api",
    "field": "published_at"
  },
  "last_updated": "2026-06-22"
}

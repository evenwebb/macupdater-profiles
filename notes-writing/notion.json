{
  "name": "Notion",
  "slug": "notion",
  "description": "All-in-one workspace for notes, wikis, and databases",
  "website": "https://notion.so",
  "platform": "macOS",
  "architecture": [
    "arm64",
    "x64"
  ],
  "min_os": "macOS 11",
  "auto_updates": true,
  "version_check": {
    "method": "yaml_api",
    "url": "https://desktop-release.notion-static.com/latest-mac.yml",
    "extraction": {
      "type": "yaml_key",
      "pattern": "version"
    },
    "headers": {}
  },
  "download": {
    "method": "constructed_url",
    "file_type": "dmg",
    "headers": {},
    "url": "https://desktop-release.notion-static.com/Notion-{version}-arm64.dmg (ARM) or Notion-{version}.dmg (x64)"
  },
  "changelog": {
    "method": "scrape",
    "url": "https://www.notion.so/releases"
  },
  "release_date": {
    "method": "yaml_field",
    "field": "releaseDate (ISO 8601)"
  },
  "notes": "Uses Electron updater YAML. Separate architecture builds (arm64, x64). No universal binary. Generic download redirect available at notion.so/desktop/mac/download.",
  "last_updated": "2026-06-21",
  "$schema": "https://raw.githubusercontent.com/evenwebb/macupdater-profiles/main/schema.json",
  "category": "notes-writing",
  "license": "free",
  "skip": false,
  "bundle_id": "notion.id"
}

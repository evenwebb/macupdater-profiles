{
  "name": "Telegram",
  "slug": "telegram",
  "description": "Cloud-based mobile and desktop messaging app",
  "website": "https://telegram.org",
  "platform": "macOS",
  "architecture": "universal",
  "min_os": "macOS 11",
  "auto_updates": true,
  "version_check": {
    "method": "sparkle_appcast",
    "url": "https://osx.telegram.org/updates/versions.xml",
    "extraction": {
      "type": "xpath",
      "xpath": "sparkle:shortVersionString (display version), sparkle:version (build number)"
    },
    "headers": {}
  },
  "download": {
    "method": "construct_url",
    "file_type": "dmg",
    "headers": {},
    "url": "https://osx.telegram.org/updates/Telegram-12.8.282010.app.zip"
  },
  "changelog": {
    "method": "scrape",
    "url": "https://desktop.telegram.org/changelog"
  },
  "release_date": {
    "method": "xml_field",
    "field": "pubDate"
  },
  "notes": "Universal single binary. Sparkle appcast XML. Files are stored as .zip on the server but Sparkle renames them to .dmg for installation.",
  "last_updated": "2026-06-21",
  "$schema": "https://raw.githubusercontent.com/evenwebb/macupdater-profiles/main/schema.json",
  "category": "messaging",
  "license": "free",
  "skip": false,
  "bundle_id": "ru.keepcoder.Telegram"
}